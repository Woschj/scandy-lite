# Automatisch generiert aus app/core/config.py::Settings - siehe
# scripts/generate_env_example.py. Nicht von Hand nachpflegen, stattdessen:
#   python -m scripts.generate_env_example

# --- App ---
APP_NAME=Scandy-Lite
# development | production - production erzwingt echte SECRET_KEY/POSTGRES_PASSWORD (siehe unten)
ENV=development
# Erzeugen mit: openssl rand -hex 32 - siehe INSTALL.md
SECRET_KEY=change-me-in-production

# --- Datenbank ---
# Async-Verbindung (asyncpg) für die laufende App
DATABASE_URL=postgresql+asyncpg://scandy:scandy@localhost:5432/scandy_lite
# Sync-Verbindung (psycopg2) - wird für Alembic-Migrationen gebraucht
DATABASE_URL_SYNC=postgresql+psycopg2://scandy:scandy@localhost:5432/scandy_lite

# --- Auth ---
ACCESS_TOKEN_EXPIRE_MINUTES=720
JWT_ALGORITHM=HS256
SESSION_COOKIE_NAME=scandy_session
# Erst auf true, wenn ein Reverse-Proxy TLS terminiert - sonst Login-Loop über HTTP
SESSION_COOKIE_SECURE=false

# --- SSO (optional, OpenID Connect - z.B. Authentik) ---
# Leer lassen = Feature aus, Login-Seite zeigt nur das lokale Formular
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Beschriftung des Login-Buttons, z.B. 'Authentik'
OIDC_PROVIDER_NAME=SSO

# --- Multi-Abteilung ---
DEFAULT_DEPARTMENT_CODE=default

# --- Bild-Uploads ---
UPLOADS_DIR=uploads
# vor der Pillow-Verarbeitung
MAX_UPLOAD_BYTES=8388608
# px, längere Kante
IMAGE_MAX_DIMENSION=900
