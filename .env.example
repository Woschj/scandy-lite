APP_NAME=Scandy-Lite
ENV=development
SECRET_KEY=change-me-in-production

DATABASE_URL=postgresql+asyncpg://scandy:scandy@localhost:5432/scandy_lite
DATABASE_URL_SYNC=postgresql+psycopg2://scandy:scandy@localhost:5432/scandy_lite

ACCESS_TOKEN_EXPIRE_MINUTES=720
SESSION_COOKIE_SECURE=false
DEFAULT_DEPARTMENT_CODE=default

# Optional: SSO via OpenID Connect (z.B. Authentik). Leer lassen = Feature
# aus, Login-Seite zeigt dann nur das lokale Formular. Erster Login legt
# automatisch ein Konto an, aber gesperrt - ein Admin muss es unter
# "Ausstehende Konten" (Link auf der Übersicht) erst freischalten.
# OIDC_ISSUER=https://authentik.example.com/application/o/scandy-lite/
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_PROVIDER_NAME=Authentik
